<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="smart_robot_arm">

  <!-- ============================================================ -->
  <!--  SmartRobotArm v1 Robot Description                          -->
  <!--  Inherited from soma_home_exp_v1 (mobile manipulator URDF).  -->
  <!--                                                              -->
  <!--  v1 hardware is a FIXED tabletop manipulator: only the       -->
  <!--  RoArm-M2-S (4-DOF) + the overhead Logitech C922 are real.   -->
  <!--  The chassis + LiDAR links are kept here for the optional    -->
  <!--  Gazebo dry-run scene; they do NOT correspond to v1 real     -->
  <!--  hardware. v2/v3 may re-introduce a mobile base.             -->
  <!--                                                              -->
  <!--  Arm parameters sourced from official Waveshare URDF:        -->
  <!--  github.com/waveshareteam/roarm_ws_em0                       -->
  <!-- ============================================================ -->

  <!-- ==================== Chassis Parameters ==================== -->
  <xacro:property name="chassis_length" value="0.30"/>
  <xacro:property name="chassis_width"  value="0.25"/>
  <xacro:property name="chassis_height" value="0.10"/>
  <xacro:property name="chassis_mass"   value="3.0"/>

  <xacro:property name="wheel_radius"     value="0.033"/>
  <xacro:property name="wheel_width"      value="0.026"/>
  <xacro:property name="wheel_mass"       value="0.1"/>
  <xacro:property name="wheel_separation" value="0.287"/>
  <xacro:property name="caster_radius"    value="0.015"/>

  <!-- ==================== RoArm-M2-S Parameters (from official URDF) ==================== -->
  <!-- Base to J1 axis height: 123.059mm -->
  <xacro:property name="arm_base_height"    value="0.123059"/>
  <!-- Base X offset: 10mm -->
  <xacro:property name="arm_base_x_offset"  value="0.010"/>
  <!-- Upper arm length (J2 to J3): 236.815mm -->
  <xacro:property name="arm_upper_length"   value="0.236815"/>
  <!-- J2-J3 Y offset: 30.002mm -->
  <xacro:property name="arm_upper_y_offset" value="0.030002"/>
  <!-- Forearm length (J3 to gripper): 215.99mm -->
  <xacro:property name="arm_forearm_length" value="0.21599"/>
  <!-- J3 to TCP: 280.2mm -->
  <xacro:property name="arm_tcp_length"     value="0.2802"/>
  <!-- Gripper offset from J3 -->
  <xacro:property name="gripper_x_offset"   value="0.002906"/>
  <xacro:property name="gripper_z_offset"   value="-0.000667"/>

  <!-- ST3215 servo specs: stall torque 2.94 N·m, no-load speed 4.71 rad/s -->
  <xacro:property name="servo_effort"   value="2.94"/>
  <xacro:property name="servo_velocity" value="4.71"/>

  <!-- ==================== Inertia Macros ==================== -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12}" iyz="0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${2*m*r*r/5}" ixy="0" ixz="0"
               iyy="${2*m*r*r/5}" iyz="0"
               izz="${2*m*r*r/5}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================== Base Link (Chassis) ==================== -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}"/>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius + chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Wheels ==================== -->
  <xacro:macro name="wheel" params="prefix y_offset">
    <link name="${prefix}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0 ${y_offset} ${-chassis_height/2}" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.01" friction="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="left"  y_offset="${wheel_separation/2}"/>
  <xacro:wheel prefix="right" y_offset="${-wheel_separation/2}"/>

  <!-- Caster wheel -->
  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <xacro:sphere_inertia m="0.05" r="${caster_radius}"/>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="${-chassis_length/2 + 0.03} 0 ${-chassis_height/2 - wheel_radius + caster_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LiDAR (RPLiDAR A1) ==================== -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.035" length="0.04"/></geometry>
      <material name="red"><color rgba="0.8 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.035" length="0.04"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.17" r="0.035" h="0.04"/>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="${-chassis_length/4} 0 ${chassis_height/2 + arm_base_height + 0.03}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Camera (RPi Camera Module 3) ==================== -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.024 0.012"/></geometry>
      <material name="green"><color rgba="0.1 0.6 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.025 0.024 0.012"/></geometry>
    </collision>
    <xacro:box_inertia m="0.02" x="0.025" y="0.024" z="0.012"/>
  </link>

  <link name="camera_optical_frame"/>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${chassis_length/4} 0 ${chassis_height/2 + 0.15}" rpy="0 0.3 0"/>
  </joint>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ============================================================ -->
  <!--  RoArm-M2-S Arm (4-DOF)                                     -->
  <!--  Kinematic chain matches official Waveshare URDF exactly     -->
  <!--  Joint names kept compatible with roarm_ws_em0               -->
  <!-- ============================================================ -->

  <!-- Arm base: fixed to chassis top plate, front-center -->
  <link name="arm_base_link">
    <visual>
      <geometry><box size="0.0985 0.0816 0.0836"/></geometry>
      <material name="blue"><color rgba="0.2 0.2 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.0985 0.0816 0.0836"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.003738 0 0.026427"/>
      <mass value="0.3264"/>
      <inertia ixx="0.000224" ixy="0" ixz="-0.0000299"
               iyy="0.000287" iyz="0"
               izz="0.000350"/>
    </inertial>
  </link>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="${chassis_length/4} 0 ${chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Joint 1: Base rotation — 360° (±180°) around Z axis -->
  <link name="arm_link1">
    <visual>
      <geometry><box size="0.0548 0.0724 0.0496"/></geometry>
      <material name="silver"><color rgba="0.7 0.7 0.7 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.0548 0.0724 0.0496"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0.0000097 -0.014667"/>
      <mass value="0.0929"/>
      <inertia ixx="0.0000609" ixy="0" ixz="0"
               iyy="0.0000253" iyz="0"
               izz="0.0000488"/>
    </inertial>
  </link>

  <joint name="base_link_to_link1" type="revolute">
    <parent link="arm_base_link"/>
    <child link="arm_link1"/>
    <origin xyz="${arm_base_x_offset} 0 ${arm_base_height}" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="${-pi}" upper="${pi}" effort="${servo_effort}" velocity="${servo_velocity}"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Joint 2: Shoulder pitch — 180° (±90°) -->
  <link name="arm_link2">
    <visual>
      <origin xyz="0.122021 0.000066 -0.000095"/>
      <geometry><box size="0.2568 0.0555 0.0790"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.122021 0 0"/>
      <geometry><box size="0.2568 0.0555 0.0790"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.122021 0.000066 -0.000095"/>
      <mass value="0.0896"/>
      <inertia ixx="0.0000263" ixy="-0.00000255" ixz="0"
               iyy="0.000350" iyz="0"
               izz="0.000333"/>
    </inertial>
  </link>

  <joint name="link1_to_link2" type="revolute">
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <origin xyz="0 0 0" rpy="${-pi/2} ${-pi/2} 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="${servo_effort*2}" velocity="${servo_velocity}"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Joint 3: Elbow pitch — from -57.3° to +180° -->
  <link name="arm_link3">
    <visual>
      <origin xyz="-0.000763 -0.114420 -0.000177"/>
      <geometry><box size="0.0355 0.2939 0.0488"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 -0.114420 0"/>
      <geometry><box size="0.0355 0.2939 0.0488"/></geometry>
    </collision>
    <inertial>
      <origin xyz="-0.000763 -0.114420 -0.000177"/>
      <mass value="0.1230"/>
      <inertia ixx="0.000104" ixy="0" ixz="0"
               iyy="0.0000146" iyz="0"
               izz="0.000104"/>
    </inertial>
  </link>

  <joint name="link2_to_link3" type="revolute">
    <parent link="arm_link2"/>
    <child link="arm_link3"/>
    <origin xyz="${arm_upper_length} ${arm_upper_y_offset} 0" rpy="0 0 ${pi/2}"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="${pi}" effort="${servo_effort}" velocity="${servo_velocity}"/>
    <dynamics damping="0.08" friction="0.04"/>
  </joint>

  <!-- Joint 4: Gripper — 0 to 85.9° (0=closed, 1.5rad=open) -->
  <link name="gripper_link">
    <visual>
      <origin xyz="0.028886 -0.000777 -0.000780"/>
      <geometry><box size="0.0779 0.0252 0.0394"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.028886 0 0"/>
      <geometry><box size="0.0779 0.0252 0.0394"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.028886 -0.000777 -0.000780"/>
      <mass value="0.00366"/>
      <inertia ixx="0.00000115" ixy="0.000000131" ixz="0"
               iyy="0.00000233" iyz="0"
               izz="0.00000147"/>
    </inertial>
  </link>

  <joint name="link3_to_gripper_link" type="revolute">
    <parent link="arm_link3"/>
    <child link="gripper_link"/>
    <origin xyz="${gripper_x_offset} ${-arm_forearm_length} ${gripper_z_offset}" rpy="${-pi/2} 0 ${-pi/2}"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="1.5" effort="${servo_effort}" velocity="${servo_velocity}"/>
    <dynamics damping="0.05" friction="0.03"/>
  </joint>

  <!-- TCP (Tool Center Point) — the actual grasp reference point -->
  <link name="hand_tcp"/>

  <joint name="link3_to_hand_tcp" type="fixed">
    <parent link="arm_link3"/>
    <child link="hand_tcp"/>
    <origin xyz="0.002 ${-arm_tcp_length} 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ==================== Gazebo Plugins ==================== -->

  <!-- Differential drive -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>20</odom_publish_frequency>
    </plugin>
  </gazebo>

  <!-- Joint state publisher for arm -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>base_link_to_link1</joint_name>
      <joint_name>link1_to_link2</joint_name>
      <joint_name>link2_to_link3</joint_name>
      <joint_name>link3_to_gripper_link</joint_name>
    </plugin>
  </gazebo>

  <!-- Joint position controller for arm -->
  <gazebo>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>base_link_to_link1</joint_name>
      <p_gain>10</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.5</d_gain>
      <topic>arm/joint1_cmd</topic>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>link1_to_link2</joint_name>
      <p_gain>20</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>1.0</d_gain>
      <topic>arm/joint2_cmd</topic>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>link2_to_link3</joint_name>
      <p_gain>15</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.8</d_gain>
      <topic>arm/joint3_cmd</topic>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>link3_to_gripper_link</joint_name>
      <p_gain>5</p_gain>
      <i_gain>0.05</i_gain>
      <d_gain>0.3</d_gain>
      <topic>arm/gripper_cmd</topic>
    </plugin>
  </gazebo>

  <!-- LiDAR sensor (RPLiDAR A1) -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- RGB Camera (RPi Camera Module 3: 66° FOV) -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <topic>camera/image_raw</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.152</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>10.0</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- Wheel friction -->
  <gazebo reference="left_wheel">
    <mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel">
    <mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="caster_wheel">
    <mu1>0.01</mu1><mu2>0.01</mu2>
  </gazebo>

</robot>
